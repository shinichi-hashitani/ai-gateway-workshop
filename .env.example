# Kong Konnect 接続設定
# export を使って deck など子プロセスからも参照できるようにする
export KONNECT_TOKEN=kpat_xxxxxxxxxxxx
export KONNECT_CONTROL_PLANE_NAME=default

# LLM プロバイダー APIキー
export OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx
export GEMINI_API_KEY=AIzaxxxxxxxxxx

# Kong Serverless ゲートウェイ プロキシURL
# Konnect コンソールの "Gateway Services" > "Serverless" から確認
export KONNECT_PROXY_URL=https://xxxxxxxxxx.us.serverless.konghq.com

# Kong Consumer 認証キー (任意の文字列を設定)
# シナリオ 1: demo-user (OpenAI) 用
export KONG_API_KEY=my-demo-key-xxxxxxxxxxxx
# シナリオ 1: gemini-user (Gemini) 用
export KONG_GEMINI_KEY=my-gemini-key-xxxxxxxxxxxx

# シナリオ 4 用 MCP サーバー URL
# ローカルで起動した MCP サーバーや mcp.run などのホスト型サービスのエンドポイントを設定
export MCP_SERVER_URL=https://your-mcp-server.example.com
